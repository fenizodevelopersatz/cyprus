[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/fenizo/fenizo-exchange.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "satheesh"]
	remote = origin
	merge = refs/heads/satheesh
	github-pr-base-branch = "fenizo#fenizo-exchange#main"
	vscode-merge-base = origin/satheesh
