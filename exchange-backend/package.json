{
    "name": "novax-backend",
    "version": "0.1.0",
    "type": "module",
    "main": "src/index.js",
    "scripts": {
        "dev": "nodemon src/index.js",
        "start": "node src/index.js",
        "worker:deposits": "node src/workers/depositMonitor.js",
        "fix:signup-bonus": "node src/scripts/removeLegacySignupBonus.js",
        "fix:wallet-balances": "node src/scripts/repairWalletBalances.js",
        "migrate": "knex migrate:latest --knexfile knexfile.js",
        "rollback": "knex migrate:rollback --knexfile knexfile.js",
        "seed": "knex seed:run --knexfile knexfile.js",
        "lint": "eslint .",
        "test": "NODE_ENV=test node ./node_modules/.bin/tap --reporter=spec"
    },
    "engines": {
        "node": "20.16.0"
    },
    "dependencies": {
        "axios": "^1.7.7",
        "bcryptjs": "^2.4.3",
        "binance-api-node": "^0.12.9",
        "celebrate": "^15.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "ethers": "^6.15.0",
        "express": "^4.22.1",
        "express-async-errors": "^3.1.1",
        "express-rate-limit": "^7.4.0",
        "helmet": "^7.1.0",
        "joi": "^17.12.2",
        "jsonwebtoken": "^9.0.3",
        "knex": "^3.1.0",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.10.3",
        "nodemailer": "^6.9.15",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "qrcode": "^1.5.3",
        "socket.io": "^4.7.5",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "tronweb": "^6.0.4",
        "uuid": "^9.0.1",
        "ws": "^8.17.1"
    },
    "devDependencies": {
        "eslint": "^9.12.0",
        "nodemon": "^3.1.7",
        "tap": "^21.0.0"
    }
}
